            },
            "accordion_row_EzXEtb": {
              "type": "_accordion-row",
              "settings": {
                "heading": "How long does the hiring process take?",
                "open_by_default": false,
                "icon": "none",
                "width": 20,
                "section_bg_color": "#ffffff"
              },
              "blocks": {
                "text_qxeFch": {
                  "type": "text",
                  "settings": {
                    "text": "<p>Timelines depend on the role and level of specialization. For most positions, shortlisting begins within a few days. We provide regular updates and aim to deliver qualified candidates as quickly as possible.</p>",
