          "blocks": {
            "accordion_row_NpzKWU": {
              "type": "_accordion-row",
              "settings": {
                "heading": "What services do you offer?",
                "open_by_default": false,
                "icon": "none",
                "width": 20,
                "section_bg_color": "#ffffff"
