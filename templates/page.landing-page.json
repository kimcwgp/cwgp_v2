              "blocks": {
                "text_krL6Yq": {
                  "type": "text",
                  "settings": {
                    "text": "<p>We provide end-to-end recruitment and staffing solutions — from sourcing and screening to onboarding and payroll management.</p>",
                    "width": "100%",
