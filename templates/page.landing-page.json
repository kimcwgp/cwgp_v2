                "open_by_default": false,
                "icon": "none",
                "width": 20,
                "section_bg_color": "#ffffff"
              },
              "blocks": {
                "text_8M6J4y": {
                  "type": "text",
                  "settings": {
                    "text": "<p>We use a combination of targeted job postings, referral networks, talent databases, and proactive headhunting. Our recruitment specialists also leverage professional platforms and industry connections to find the best candidates.</p>",
                    "width": "100%",
                    "max_width": "none",
                    "alignment": "left",
                    "type_preset": "rte",
