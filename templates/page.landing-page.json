              ]
            },
            "accordion_row_bH7EBG": {
              "type": "_accordion-row",
              "settings": {
                "heading": "What industries do you specialize in?",
                "open_by_default": false,
                "icon": "none",
                "width": 20,
                "section_bg_color": "#ffffff"
              },
              "blocks": {
                "text_NamDqm": {
                  "type": "text",
                  "settings": {
                    "text": "<p>We specialize in professional, technical, and administrative roles across multiple industries such as IT, Finance, Marketing, Sales, Engineering, and Operations. We tailor our approach based on your sector and requirements.</p>",
                    "width": "100%",
                    "max_width": "none",
                    "alignment": "left",
                    "type_preset": "rte",
                    "font": "var(--font-body--family)",
                    "font_color": "#000000",
