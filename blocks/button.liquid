
{% render 'button', link: block.settings.link %}

{% schema %}
{
  "name": "t:names.button",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "t:settings.label",
      "default": "t:text_defaults.button_label"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:settings.link"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "t:settings.open_new_tab",
      "default": false
    },
    {
      "type": "select",
      "id": "style_class",
      "label": "t:settings.style",
      "options": [
        {
          "value": "button",
          "label": "t:options.primary"
        },
        {
          "value": "button-secondary",
          "label": "t:options.secondary"
        },
        {
          "value": "link",
          "label": "t:options.link"
        },
        { "value": "primary-square-btn", "label": "Primary Square Button" },
        { "value": "uiverse-btn", "label": "Uiverse Button" },
        { "value": "uiverse-btn-wht", "label": "Uiverse Button White" },
        { "value": "uiverse-btn-mblue", "label": "Uiverse Button MidBlue" },
        { "value": "btn-elegant", "label": "Elegant Button" },
        { "value": "btn-slide", "label": "Slide Button" },
        { "value": "orange-btn", "label": "Orange Button" },
        { "value": "orange-pill-btn", "label": "Orange Pill Button" },
        { "value": "orange-pill-arrow-btn", "label": "Orange Pill with Arrow Button" },
        { "value": "orange-outline-btn", "label": "Orange Outline Button" },
        { "value": "orange-outline-pill-btn", "label": "Orange Outline Pill Button" },
        { "value": "orange-outline-pill-arrow-btn", "label": "Orange Outline Pill with Arrow Button" },
        { "value": "black_outline", "label": "Black Outline"},
        { "value": "black_outline_arrow", "label": "Black Outline with Arrow"},
        { "value": "white_outline", "label": "White Outline"},
        { "value": "hyperlink", "label": "Hyperlink"},
        { "value": "arrow-link-btn", "label": "Arrow Link Button" },
      ],
      "default": "button"
    },
    {
      "type": "header",
      "content": "t:content.size"
    },
    {
      "type": "select",
      "id": "width",
      "label": "t:settings.width_desktop",
      "options": [
        {
          "value": "fit-content",
          "label": "t:options.fit_content"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "fit-content"
    },
    {
      "type": "range",
      "id": "custom_width",
      "label": "t:settings.custom_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width == \"custom\" }}"
    },
    {
      "type": "select",
      "id": "width_mobile",
      "label": "t:settings.width_mobile",
      "options": [
        {
          "value": "fit-content",
          "label": "t:options.fit_content"
        },
        {
          "value": "custom",
          "label": "t:options.custom"
        }
      ],
      "default": "fit-content"
    },
    {
      "type": "range",
      "id": "custom_width_mobile",
      "label": "t:settings.custom_width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,
      "visible_if": "{{ block.settings.width_mobile == \"custom\" }}"
    }
  ],
  "presets": [
    {
      "name": "t:names.button",
      "category": "t:categories.basic",
      "settings": {
        "link": "shopify://collections/all"
      }
    }
  ]
}
{% endschema %}
