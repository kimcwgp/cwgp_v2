{% doc %}
  @prompt
    A icons with text but a slider, Instead of icons it should be Image, and I wanted to add more Item not just 6 max only
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-slider-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-image-slider-container-{{ ai_gen_id }} {
    max-width: 1980px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-image-slider-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.content_spacing }}px;
  }

  .ai-image-slider-title-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.title_size }}px;
    margin: 0 0 10px;
    font-weight: 700;
  }

  .ai-image-slider-subtitle-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.subtitle_size }}px;
    margin: 0;
    opacity: 0.8;
  }

  .ai-image-slider-wrapper-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-image-slider-track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.3s ease;
    gap: {{ block.settings.item_spacing }}px;
  }

  .ai-image-slider-item-{{ ai_gen_id }} {
    flex: 0 0 auto;
    width: {{ block.settings.item_width }}px;
    text-align: center;
    padding: {{ block.settings.item_padding }}px;
    background-color: {{ block.settings.item_background_color }};
    border-radius: {{ block.settings.item_border_radius }}px;
    border: {{ block.settings.item_border_width }}px solid {{ block.settings.item_border_color }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-image-slider-item-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.hover_lift }}px);
    box-shadow: 0 {{ block.settings.hover_lift | times: 2 }}px {{ block.settings.hover_lift | times: 4 }}px rgba(0, 0, 0, 0.1);
  }

  .ai-image-slider-image-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.image_size }}px;
    height: {{ block.settings.image_size }}px;
    margin: 0 auto {{ block.settings.image_spacing }}px;
    background-color: {{ block.settings.image_background_color }};
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-image-slider-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-image-slider-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-image-slider-image-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-image-slider-item-title-{{ ai_gen_id }} {
    color: {{ block.settings.item_title_color }};
    font-size: {{ block.settings.item_title_size }}px;
    font-weight: 600;
    margin: 0 0 8px;
  }

  .ai-image-slider-item-text-{{ ai_gen_id }} {
    color: {{ block.settings.item_text_color }};
    font-size: {{ block.settings.item_text_size }}px;
    line-height: 1.4;
    margin: 0;
  }

  .ai-image-slider-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.nav_background_color }};
    border: none;
    border-radius: 50%;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: {{ block.settings.nav_color }};
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
    z-index: 2;
  }

  .ai-image-slider-nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_hover_background_color }};
    color: {{ block.settings.nav_hover_color }};
    transform: translateY(-50%) scale(1.1);
  }

  .ai-image-slider-nav-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
    transform: translateY(-50%) scale(1);
  }

  .ai-image-slider-nav-prev-{{ ai_gen_id }} {
    left: -22px;
  }

  .ai-image-slider-nav-next-{{ ai_gen_id }} {
    right: -22px;
  }

  .ai-image-slider-dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: {{ block.settings.content_spacing }}px;
  }

  .ai-image-slider-dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    opacity: 0.3;
  }

  .ai-image-slider-dot-{{ ai_gen_id }}.active {
    opacity: 1;
    background-color: {{ block.settings.dot_active_color }};
  }

  @media screen and (max-width: 768px) {
    .ai-image-slider-item-{{ ai_gen_id }} {
      width: {{ block.settings.item_width | times: 0.8 }}px;
    }

    .ai-image-slider-nav-{{ ai_gen_id }} {
      display: none;
    }

    .ai-image-slider-container-{{ ai_gen_id }} {
      padding: 0 10px;
    }
  }
{% endstyle %}

<image-slider-{{ ai_gen_id }}
  class="ai-image-slider-{{ ai_gen_id }}"
  data-items-per-view="{{ block.settings.items_per_view }}"
  data-auto-play="{{ block.settings.auto_play }}"
  data-auto-play-speed="{{ block.settings.auto_play_speed }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-image-slider-container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.subtitle != blank %}
      <div class="ai-image-slider-header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-image-slider-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <p class="ai-image-slider-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-image-slider-wrapper-{{ ai_gen_id }}">
      <button class="ai-image-slider-nav-{{ ai_gen_id }} ai-image-slider-nav-prev-{{ ai_gen_id }}" aria-label="Previous slide">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15,18 9,12 15,6"></polyline>
        </svg>
      </button>

      <div class="ai-image-slider-track-{{ ai_gen_id }}">
        {% for i in (1..12) %}
          {% liquid
            assign image_key = 'image_' | append: i
            assign title_key = 'title_' | append: i
            assign text_key = 'text_' | append: i
            assign enabled_key = 'item_' | append: i | append: '_enabled'

            assign image_setting = block.settings[image_key]
            assign title_setting = block.settings[title_key]
            assign text_setting = block.settings[text_key]
            assign enabled_setting = block.settings[enabled_key]
          %}

          {% if enabled_setting %}
            <div class="ai-image-slider-item-{{ ai_gen_id }}">
              <div class="ai-image-slider-image-wrapper-{{ ai_gen_id }}">
                {% if image_setting %}
                  <img
                    src="{{ image_setting | image_url: width: 200 }}"
                    alt="{{ image_setting.alt | escape }}"
                    class="ai-image-slider-image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="200"
                    height="200"
                  >
                {% else %}
                  <div class="ai-image-slider-image-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>
              {% if title_setting != blank %}
                <h3 class="ai-image-slider-item-title-{{ ai_gen_id }}">{{ title_setting }}</h3>
              {% endif %}
              {% if text_setting != blank %}
                <p class="ai-image-slider-item-text-{{ ai_gen_id }}">{{ text_setting }}</p>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>

      <button class="ai-image-slider-nav-{{ ai_gen_id }} ai-image-slider-nav-next-{{ ai_gen_id }}" aria-label="Next slide">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9,18 15,12 9,6"></polyline>
        </svg>
      </button>
    </div>

    {% if block.settings.show_dots %}
      <div class="ai-image-slider-dots-{{ ai_gen_id }}"></div>
    {% endif %}
  </div>
</image-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.itemsPerView = parseInt(this.dataset.itemsPerView) || 3;
        this.autoPlay = this.dataset.autoPlay === 'true';
        this.autoPlaySpeed = parseInt(this.dataset.autoPlaySpeed) || 3000;
        this.autoPlayInterval = null;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-image-slider-track-{{ ai_gen_id }}');
        this.items = this.querySelectorAll('.ai-image-slider-item-{{ ai_gen_id }}');
        this.prevBtn = this.querySelector('.ai-image-slider-nav-prev-{{ ai_gen_id }}');
        this.nextBtn = this.querySelector('.ai-image-slider-nav-next-{{ ai_gen_id }}');
        this.dotsContainer = this.querySelector('.ai-image-slider-dots-{{ ai_gen_id }}');

        if (this.items.length === 0) return;

        this.totalSlides = Math.max(0, this.items.length - this.itemsPerView + 1);
        
        this.setupEventListeners();
        this.createDots();
        this.updateSlider();
        
        if (this.autoPlay && this.totalSlides > 1) {
          this.startAutoPlay();
        }

        this.setupResponsive();
      }

      setupEventListeners() {
        this.prevBtn.addEventListener('click', () => this.prevSlide());
        this.nextBtn.addEventListener('click', () => this.nextSlide());

        this.addEventListener('mouseenter', () => this.stopAutoPlay());
        this.addEventListener('mouseleave', () => {
          if (this.autoPlay) this.startAutoPlay();
        });
      }

      setupResponsive() {
        const updateItemsPerView = () => {
          if (window.innerWidth <= 768) {
            this.itemsPerView = Math.min(2, this.items.length);
          } else if (window.innerWidth <= 1024) {
            this.itemsPerView = Math.min(3, this.items.length);
          } else {
            this.itemsPerView = Math.min(parseInt(this.dataset.itemsPerView) || 3, this.items.length);
          }
          
          this.totalSlides = Math.max(0, this.items.length - this.itemsPerView + 1);
          this.currentSlide = Math.min(this.currentSlide, this.totalSlides - 1);
          this.updateSlider();
          this.createDots();
        };

        window.addEventListener('resize', updateItemsPerView);
        updateItemsPerView();
      }

      createDots() {
        if (!this.dotsContainer) return;
        
        this.dotsContainer.innerHTML = '';
        
        for (let i = 0; i < this.totalSlides; i++) {
          const dot = document.createElement('button');
          dot.className = `ai-image-slider-dot-{{ ai_gen_id }} ${i === this.currentSlide ? 'active' : ''}`;
          dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
          dot.addEventListener('click', () => this.goToSlide(i));
          this.dotsContainer.appendChild(dot);
        }
      }

      updateSlider() {
        if (!this.track || this.items.length === 0) return;

        const itemWidth = this.items[0].offsetWidth;
        const gap = parseInt(getComputedStyle(this.track).gap) || 0;
        const translateX = -(this.currentSlide * (itemWidth + gap));
        
        this.track.style.transform = `translateX(${translateX}px)`;

        this.prevBtn.disabled = this.currentSlide === 0;
        this.nextBtn.disabled = this.currentSlide >= this.totalSlides - 1;

        this.updateDots();
      }

      updateDots() {
        const dots = this.querySelectorAll('.ai-image-slider-dot-{{ ai_gen_id }}');
        dots.forEach((dot, index) => {
          dot.classList.toggle('active', index === this.currentSlide);
        });
      }

      prevSlide() {
        if (this.currentSlide > 0) {
          this.currentSlide--;
          this.updateSlider();
        }
      }

      nextSlide() {
        if (this.currentSlide < this.totalSlides - 1) {
          this.currentSlide++;
          this.updateSlider();
        } else if (this.autoPlay) {
          this.currentSlide = 0;
          this.updateSlider();
        }
      }

      goToSlide(index) {
        this.currentSlide = Math.max(0, Math.min(index, this.totalSlides - 1));
        this.updateSlider();
      }

      startAutoPlay() {
        this.stopAutoPlay();
        if (this.totalSlides > 1) {
          this.autoPlayInterval = setInterval(() => {
            this.nextSlide();
          }, this.autoPlaySpeed);
        }
      }

      stopAutoPlay() {
        if (this.autoPlayInterval) {
          clearInterval(this.autoPlayInterval);
          this.autoPlayInterval = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoPlay();
      }
    }

    customElements.define('image-slider-{{ ai_gen_id }}', ImageSlider{{ ai_gen_id }});
  })();
</script>

