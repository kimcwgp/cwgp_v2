<div class="scrollable-wrapper" id="scrollable-{{ block.id }}">
  <div class="scrollable-track">

    {% for i in (1..7) %}
      {% assign img = "image_" | append: i %}
      {% assign txt = "text_" | append: i %}

      <div class="scroll-item">

        {% if block.settings[img] != blank %}
          <img 
            src="{{ block.settings[img] | image_url: width: 600 }}"
            loading="lazy"
          >
        {% endif %}

        {% if block.settings[txt] != blank %}
          <p>{{ block.settings[txt] }}</p>
        {% endif %}

      </div>
    {% endfor %}

  </div>
</div>
<style>
.scrollable-wrapper {
  width: 100%;
  overflow: hidden; /* hides scrollbar completely */
}

.scrollable-track {
  display: flex;
  flex-wrap: nowrap;
  gap: 16px;

  overflow-x: auto;  /* still scrollable */
  overflow-y: hidden;

  cursor: grab;

  scrollbar-width: none; /* Firefox */
  -ms-overflow-style: none; /* IE/Edge legacy */

  scroll-behavior: auto;
}

.scrollable-track::-webkit-scrollbar {
  display: none; /* Chrome/Safari */
}

.scroll-item {
  flex: 0 0 auto;
  width: 250px;
}

/* dragging state */
.scrollable-track.dragging {
  cursor: grabbing;
  user-select: none;
}

</style>

<script>
(function () {
  const wrapper = document.getElementById("scrollable-{{ block.id }}");
  const track = wrapper.querySelector(".scrollable-track");

  let isDown = false;
  let startX;
  let scrollStart;

  track.addEventListener("mousedown", (e) => {
    isDown = true;
    track.classList.add("dragging");

    startX = e.clientX;
    scrollStart = track.scrollLeft;
  });

  track.addEventListener("mouseup", () => {
    isDown = false;
    track.classList.remove("dragging");
  });

  track.addEventListener("mouseleave", () => {
    isDown = false;
    track.classList.remove("dragging");
  });

  track.addEventListener("mousemove", (e) => {
    if (!isDown) return;
    e.preventDefault();

    const x = e.clientX;
    const walk = (x - startX) * 1.5;

    track.scrollLeft = scrollStart - walk;
  });

  // touch
  track.addEventListener("touchstart", (e) => {
    isDown = true;
    startX = e.touches[0].clientX;
    scrollStart = track.scrollLeft;
  });

  track.addEventListener("touchmove", (e) => {
    if (!isDown) return;

    const x = e.touches[0].clientX;
    const walk = (x - startX) * 1.5;

    track.scrollLeft = scrollStart - walk;
  }, { passive: true });

  track.addEventListener("touchend", () => {
    isDown = false;
  });
})();
</script>

