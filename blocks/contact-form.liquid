{% comment %}
  Block: Stylish Form Block
  Description: A dark form block with orange accent (#C7963D)
{% endcomment %}

<div class="custom-form-block" id="custom-form-block-{{ block.id }}">
  <div class="form-container">
    <span class="heading">
      {{ block.settings.heading }}
    </span>

    <form method="post" action="/contact#contact_form" id="contact_form" accept-charset="UTF-8" class="form">
      <input type="hidden" name="form_type" value="contact">
      <input type="hidden" name="utf8" value="✓">

      <input type="text" class="input" name="contact[name]" placeholder="Name" required>
      <input type="email" class="input" name="contact[email]" placeholder="Email" required>
      <textarea class="textarea" name="contact[body]" placeholder="Message"></textarea>

      <div class="button-container">
        <div class="reset-button-container">
          <button type="reset" class="reset-button">
            {{ block.settings.reset_button_label }}
          </button>
        </div>

        <button type="submit" class="send-button">
          {{ block.settings.send_button_label }}
        </button>

      </div>
    </form>
  </div>

  <style>
    #custom-form-block-{{ block.id }} .orange {
      color: #C7963D;
    }

    #custom-form-block-{{ block.id }} .form-container {
      max-width: 700px;
      margin: 50px auto;
      margin-top: 0px;
      background-color: #fff;
      padding: 50px 40px;
      border-radius: 16px;
      min-height: 350px;
      box-shadow: 0 6px 12px rgba(0, 0, 0, 0.06);
    }

    #custom-form-block-{{ block.id }} .heading {
      display: block;
      color: #090838;
      font-size: 2rem;
      font-weight: 800;
      margin-bottom: 30px;
      text-align: left;
    }

    #custom-form-block-{{ block.id }} .form .input {
      color: #0A2647;
      width: 100%;
      background-color: #ffffff;
      border: 1px solid #090838;
      outline: none;
      padding: 14px;
      margin-bottom: 25px;
      font-weight: bold;
      transition: all 0.2s ease-in-out;
      border-radius: 4px;
      font-size: 1rem;
    }

    {% comment %} #custom-form-block-{{ block.id }} .form .input:focus {
      border-left: 5px solid #C7963D;
    } {% endcomment %}

    #custom-form-block-{{ block.id }} .form .textarea {
      width: 100%;
      padding: 14px;
      border: none;
      outline: none;
      background-color: #ffffff;
      color: #0A2647;
      font-weight: bold;
      resize: none;
      min-height: 200px;
      margin-bottom: 25px;
      border: 1px solid #090838;
      transition: all 0.2s ease-in-out;
      border-radius: 4px;
      font-size: 1rem;
    }
    {% comment %} 
    #custom-form-block-{{ block.id }} .form .textarea:focus {
      border-left: 5px solid #C7963D;
    } {% endcomment %}

    #custom-form-block-{{ block.id }} .form .button-container {
      display: flex;
      gap: 15px;
      margin-top: 10px;
    }

    #custom-form-block-{{ block.id }} .form .send-button {
      flex-basis: 70%;
      background: #C7963D;
      padding: 12px;
      color: #fff;
      text-align: center;
      font-weight: bold;
      border: 1px solid transparent;
      transition: all 0.2s ease-in-out;
      cursor: pointer;
      border-radius: 4px;
      font-size: 1rem;
      border-radius: 100px
    }

    #custom-form-block-{{ block.id }} .form .send-button:hover {
      background: #090838;
      border: 1px solid #090838;
      color: #fff;
    }

    #custom-form-block-{{ block.id }} .form .reset-button-container {
      flex-basis: 30%;
    }

    #custom-form-block-{{ block.id }} .form .reset-button {
      position: relative;
      text-align: center;
      padding: 12px;
      color: #090838;
      background: #fff;
      transition: all 0.2s ease-in-out;
      cursor: pointer;
      border-radius: 100px;
      width: 100%;
      font-size: 1rem;
    }

    #custom-form-block-{{ block.id }} .form .reset-button:hover {
      background: #090838;
      color: #fff;
    }

    @media screen and (max-width: 749px) {
      #custom-form-block-{{ block.id }} .form-container {
        padding: 20px;
      }
      #custom-form-block-{{ block.id }} .form-container .heading {
        font-size: 20px;
      }
      #custom-form-block-{{ block.id }} .form .input,
      #custom-form-block-{{ block.id }} .form .textarea,
      #custom-form-block-{{ block.id }} .form .reset-button,
      #custom-form-block-{{ block.id }} .button-container .send-button {
        font-size: 14px;
      }

      #custom-form-block-{{ block.id }} .form .reset-button,
      #custom-form-block-{{ block.id }} .button-container .send-button {
        padding: 8px;
      }
    }
  </style>
</div>

{% schema %}
{
  "name": "Custom Form Block",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Form Heading",
      "default": "Get in touch with us"
    },
    {
      "type": "text",
      "id": "send_button_label",
      "label": "Send Button Label",
      "default": "Send Message"
    },
    {
      "type": "text",
      "id": "reset_button_label",
      "label": "Reset Button Label",
      "default": "Reset"
    }
  ],
  "presets": [
    {
      "name": "CWGP Form Block",
      "category": "t:categories.basic"
    }
  ]
}
{% endschema %}
