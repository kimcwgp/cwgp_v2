{% doc %}
  @prompt
    I need a section that tells a process. Like Step 1 and so on.. each process has image, heading and text. and make sure this section is slider and per view is 4 process. and its responsive if 1 process has been remove
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-process-steps-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-process-steps-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-process-steps-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-process-steps-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px;
    font-weight: 700;
  }

  .ai-process-steps-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-process-steps-slider-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
  }

  .ai-process-steps-slider-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.3s ease;
    gap: {{ block.settings.gap }}px;
  }

  .ai-process-step-{{ ai_gen_id }} {
    flex: 0 0 calc(25% - {{ block.settings.gap | times: 3 | divided_by: 4 }}px);
    background-color: {{ block.settings.card_background_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    text-align: center;
    box-shadow: {{ block.settings.card_shadow_opacity | divided_by: 100.0 | times: 0.1 }} {{ block.settings.card_shadow_opacity | divided_by: 100.0 | times: 0.2 }} {{ block.settings.card_shadow_opacity | divided_by: 100.0 | times: 0.3 }} rgba(0, 0, 0, {{ block.settings.card_shadow_opacity | divided_by: 100.0 }});
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
  }

  .ai-process-step-number-{{ ai_gen_id }} {
    width: {{ block.settings.step_number_size }}px;
    height: {{ block.settings.step_number_size }}px;
    background-color: {{ block.settings.step_number_bg_color }};
    color: {{ block.settings.step_number_text_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: {{ block.settings.step_number_font_size }}px;
    font-weight: 700;
    margin: 0 auto 20px;
  }

  .ai-process-step-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    margin-bottom: 20px;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
  }

  .ai-process-step-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-process-step-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-process-step-image-placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
    opacity: 0.5;
  }

  .ai-process-step-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.step_heading_size }}px;
    color: {{ block.settings.step_heading_color }};
    margin: 0 0 12px;
    font-weight: 600;
  }

  .ai-process-step-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.step_text_size }}px;
    color: {{ block.settings.step_text_color }};
    line-height: 1.5;
    margin: 0;
  }

  .ai-process-steps-navigation-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: 30px;
  }

  .ai-process-steps-nav-button-{{ ai_gen_id }} {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: {{ block.settings.nav_button_bg_color }};
    color: {{ block.settings.nav_button_text_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .ai-process-steps-nav-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_button_hover_bg_color }};
    color: {{ block.settings.nav_button_hover_text_color }};
  }

  .ai-process-steps-nav-button-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .ai-process-steps-dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-process-steps-dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_inactive_color }};
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-process-steps-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
  }

  @media screen and (max-width: 990px) {
    .ai-process-step-{{ ai_gen_id }} {
      flex: 0 0 calc(50% - {{ block.settings.gap | divided_by: 2 }}px);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-process-steps-container-{{ ai_gen_id }} {
      padding: 0 16px;
    }

    .ai-process-step-{{ ai_gen_id }} {
      flex: 0 0 calc(100% - 0px);
    }

    .ai-process-steps-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-process-steps-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<process-steps-slider-{{ ai_gen_id }}
  class="ai-process-steps-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-process-steps-container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.subtitle != blank %}
      <div class="ai-process-steps-header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-process-steps-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <p class="ai-process-steps-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-process-steps-slider-wrapper-{{ ai_gen_id }}">
      <div class="ai-process-steps-slider-{{ ai_gen_id }}" data-slider>
        {% for i in (1..6) %}
          {% liquid
            assign step_enabled_key = 'step_' | append: i | append: '_enabled'
            assign step_image_key = 'step_' | append: i | append: '_image'
            assign step_heading_key = 'step_' | append: i | append: '_heading'
            assign step_text_key = 'step_' | append: i | append: '_text'

            assign step_enabled = block.settings[step_enabled_key]
            assign step_image = block.settings[step_image_key]
            assign step_heading = block.settings[step_heading_key]
            assign step_text = block.settings[step_text_key]
          %}

          {% if step_enabled %}
            <div class="ai-process-step-{{ ai_gen_id }}" data-step="{{ i }}">
              {% if block.settings.show_step_numbers %}
                <div class="ai-process-step-number-{{ ai_gen_id }}">{{ i }}</div>
              {% endif %}

              <div class="ai-process-step-image-{{ ai_gen_id }}">
                {% if step_image %}
                  <img
                    src="{{ step_image | image_url: width: 400 }}"
                    alt="{{ step_image.alt | escape }}"
                    loading="lazy"
                    width="400"
                    height="{{ block.settings.image_height }}"
                  >
                {% else %}
                  <div class="ai-process-step-image-placeholder-{{ ai_gen_id }}">
                    {{ 'image' | placeholder_svg_tag }}
                  </div>
                {% endif %}
              </div>

              {% if step_heading != blank %}
                <h3 class="ai-process-step-heading-{{ ai_gen_id }}">{{ step_heading }}</h3>
              {% endif %}

              {% if step_text != blank %}
                <p class="ai-process-step-text-{{ ai_gen_id }}">{{ step_text }}</p>
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <div class="ai-process-steps-navigation-{{ ai_gen_id }}">
      <button
        class="ai-process-steps-nav-button-{{ ai_gen_id }}"
        data-prev
        aria-label="Previous steps"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="15,18 9,12 15,6"></polyline>
        </svg>
      </button>

      <div class="ai-process-steps-dots-{{ ai_gen_id }}" data-dots></div>

      <button
        class="ai-process-steps-nav-button-{{ ai_gen_id }}"
        data-next
        aria-label="Next steps"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="9,18 15,12 9,6"></polyline>
        </svg>
      </button>
    </div>
  </div>
</process-steps-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class ProcessStepsSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.slidesPerView = 4;
        this.gap = {{ block.settings.gap }};
      }

      connectedCallback() {
        this.slider = this.querySelector('[data-slider]');
        this.prevButton = this.querySelector('[data-prev]');
        this.nextButton = this.querySelector('[data-next]');
        this.dotsContainer = this.querySelector('[data-dots]');
        this.steps = this.querySelectorAll('.ai-process-step-{{ ai_gen_id }}');

        this.updateSlidesPerView();
        this.createDots();
        this.updateSlider();
        this.setupEventListeners();

        window.addEventListener('resize', () => {
          this.updateSlidesPerView();
          this.createDots();
          this.updateSlider();
        });
      }

      updateSlidesPerView() {
        const width = window.innerWidth;
        if (width <= 749) {
          this.slidesPerView = 1;
        } else if (width <= 990) {
          this.slidesPerView = 2;
        } else {
          this.slidesPerView = 4;
        }
      }

      get totalSlides() {
        return Math.ceil(this.steps.length / this.slidesPerView);
      }

      createDots() {
        this.dotsContainer.innerHTML = '';
        for (let i = 0; i < this.totalSlides; i++) {
          const dot = document.createElement('button');
          dot.className = 'ai-process-steps-dot-{{ ai_gen_id }}';
          dot.setAttribute('data-slide', i);
          dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
          if (i === this.currentSlide) {
            dot.classList.add('active');
          }
          this.dotsContainer.appendChild(dot);
        }
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.prevSlide());
        this.nextButton.addEventListener('click', () => this.nextSlide());

        this.dotsContainer.addEventListener('click', (e) => {
          if (e.target.hasAttribute('data-slide')) {
            this.goToSlide(parseInt(e.target.getAttribute('data-slide')));
          }
        });
      }

      prevSlide() {
        if (this.currentSlide > 0) {
          this.currentSlide--;
          this.updateSlider();
        }
      }

      nextSlide() {
        if (this.currentSlide < this.totalSlides - 1) {
          this.currentSlide++;
          this.updateSlider();
        }
      }

      goToSlide(slideIndex) {
        this.currentSlide = slideIndex;
        this.updateSlider();
      }

      updateSlider() {
        const slideWidth = 100 / this.slidesPerView;
        const translateX = -this.currentSlide * slideWidth;
        this.slider.style.transform = `translateX(${translateX}%)`;

        this.prevButton.disabled = this.currentSlide === 0;
        this.nextButton.disabled = this.currentSlide === this.totalSlides - 1;

        this.dotsContainer.querySelectorAll('.ai-process-steps-dot-{{ ai_gen_id }}').forEach((dot, index) => {
          dot.classList.toggle('active', index === this.currentSlide);
        });
      }
    }

    customElements.define('process-steps-slider-{{ ai_gen_id }}', ProcessStepsSlider{{ ai_gen_id }});
  })();
</script>

