{% doc %}
  @prompt
    create a section that tells a process, and each process has image, heading and text, it should slider because its too long if this is the layout
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-process-steps-{{ ai_gen_id }} {
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-process-steps-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-process-steps-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-process-steps-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px;
    font-weight: 700;
  }

  .ai-process-steps-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-process-slider-wrapper-{{ ai_gen_id }} {
    position: relative;
    margin-top: {{ block.settings.content_spacing }}px;
  }

  .ai-process-slider-{{ ai_gen_id }} {
    overflow: hidden;
    position: relative;
  }

  .ai-process-slider-track-{{ ai_gen_id }} {
    display: flex;
    transition: transform 0.3s ease;
    gap: {{ block.settings.step_spacing }}px;
  }

  .ai-process-step-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.slide_width }}px;
    text-align: center;
    position: relative;
  }

  .ai-process-step-number-{{ ai_gen_id }} {
    position: absolute;
    top: -10px;
    left: 50%;
    transform: translateX(-50%);
    width: {{ block.settings.number_size }}px;
    height: {{ block.settings.number_size }}px;
    background-color: {{ block.settings.number_bg_color }};
    color: {{ block.settings.number_text_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: {{ block.settings.number_font_size }}px;
    z-index: 2;
    border: 3px solid {{ block.settings.background_color }};
  }

  .ai-process-step-image-wrapper-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.image_spacing }}px;
    position: relative;
  }

  .ai-process-step-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    object-fit: cover;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-process-step-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-process-step-image-placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
    opacity: 0.3;
  }

  .ai-process-step-content-{{ ai_gen_id }} {
    padding: 0 16px;
  }

  .ai-process-step-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.step_title_size }}px;
    color: {{ block.settings.step_title_color }};
    margin: 0 0 12px;
    font-weight: 600;
  }

  .ai-process-step-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.step_text_size }}px;
    color: {{ block.settings.step_text_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-process-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 12px;
    color: #999;
    text-align: center;
    pointer-events: none;
  }

  .ai-process-slider-controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
    margin-top: 30px;
  }

  .ai-process-slider-btn-{{ ai_gen_id }} {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-color: {{ block.settings.control_bg_color }};
    color: {{ block.settings.control_text_color }};
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .ai-process-slider-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.control_hover_bg_color }};
    color: {{ block.settings.control_hover_text_color }};
  }

  .ai-process-slider-btn-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-process-slider-btn-{{ ai_gen_id }} svg {
    width: 20px;
    height: 20px;
  }

  .ai-process-slider-dots-{{ ai_gen_id }} {
    display: flex;
    gap: 8px;
  }

  .ai-process-slider-dot-{{ ai_gen_id }} {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    cursor: pointer;
    transition: all 0.3s ease;
    opacity: 0.3;
  }

  .ai-process-slider-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    opacity: 1;
  }

  @media screen and (max-width: 768px) {
    .ai-process-step-{{ ai_gen_id }} {
      flex: 0 0 {{ block.settings.slide_width | times: 0.8 }}px;
    }

    .ai-process-step-image-{{ ai_gen_id }},
    .ai-process-step-image-placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.image_height | times: 0.8 }}px;
    }

    .ai-process-steps-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-process-step-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.step_title_size | times: 0.9 }}px;
    }
  }

  @media screen and (max-width: 480px) {
    .ai-process-step-{{ ai_gen_id }} {
      flex: 0 0 280px;
    }
  }
{% endstyle %}

<process-steps-slider-{{ ai_gen_id }} class="ai-process-steps-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-process-steps-container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.subtitle != blank %}
      <div class="ai-process-steps-header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-process-steps-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtitle != blank %}
          <div class="ai-process-steps-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-process-slider-wrapper-{{ ai_gen_id }}">
      <div class="ai-process-slider-{{ ai_gen_id }}">
        <div class="ai-process-slider-track-{{ ai_gen_id }}">
          {% assign step_count = 0 %}
          {% for i in (1..6) %}
            {% liquid
              assign step_enabled_key = 'step_' | append: i | append: '_enabled'
              assign step_image_key = 'step_' | append: i | append: '_image'
              assign step_title_key = 'step_' | append: i | append: '_title'
              assign step_text_key = 'step_' | append: i | append: '_text'

              assign step_enabled = block.settings[step_enabled_key]
              assign step_image = block.settings[step_image_key]
              assign step_title = block.settings[step_title_key]
              assign step_text = block.settings[step_text_key]
            %}

            {% if step_enabled %}
              {% assign step_count = step_count | plus: 1 %}
              <div class="ai-process-step-{{ ai_gen_id }}" data-step="{{ step_count }}">
                {% if block.settings.show_numbers %}
                  <div class="ai-process-step-number-{{ ai_gen_id }}">{{ step_count }}</div>
                {% endif %}

                <div class="ai-process-step-image-wrapper-{{ ai_gen_id }}">
                  {% if step_image %}
                    <img
                      src="{{ step_image | image_url: width: 600 }}"
                      alt="{{ step_image.alt | escape }}"
                      class="ai-process-step-image-{{ ai_gen_id }}"
                      loading="lazy"
                      width="{{ step_image.width }}"
                      height="{{ step_image.height }}"
                    >
                  {% else %}
                    <div class="ai-process-step-image-placeholder-{{ ai_gen_id }}">
                      {{ 'image' | placeholder_svg_tag }}
                      <div class="ai-process-empty-state-{{ ai_gen_id }}">
                        Add an image for step {{ step_count }}
                      </div>
                    </div>
                  {% endif %}
                </div>

                <div class="ai-process-step-content-{{ ai_gen_id }}">
                  {% if step_title != blank %}
                    <h3 class="ai-process-step-heading-{{ ai_gen_id }}">{{ step_title }}</h3>
                  {% endif %}
                  {% if step_text != blank %}
                    <div class="ai-process-step-text-{{ ai_gen_id }}">{{ step_text }}</div>
                  {% endif %}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      {% if step_count > 1 %}
        <div class="ai-process-slider-controls-{{ ai_gen_id }}">
          <button class="ai-process-slider-btn-{{ ai_gen_id }} ai-process-prev-{{ ai_gen_id }}" aria-label="Previous step">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15,18 9,12 15,6"></polyline>
            </svg>
          </button>

          <div class="ai-process-slider-dots-{{ ai_gen_id }}">
            {% for i in (1..step_count) %}
              <button class="ai-process-slider-dot-{{ ai_gen_id }}{% if forloop.first %} active{% endif %}" data-slide="{{ forloop.index0 }}" aria-label="Go to step {{ i }}"></button>
            {% endfor %}
          </div>

          <button class="ai-process-slider-btn-{{ ai_gen_id }} ai-process-next-{{ ai_gen_id }}" aria-label="Next step">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9,18 15,12 9,6"></polyline>
            </svg>
          </button>
        </div>
      {% endif %}
    </div>
  </div>
</process-steps-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class ProcessStepsSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.slidesPerView = {{ block.settings.slides_per_view }};
        this.autoplay = {{ block.settings.autoplay }};
        this.autoplayDelay = {{ block.settings.autoplay_delay }};
        this.autoplayTimer = null;
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-process-slider-track-{{ ai_gen_id }}');
        this.slides = this.querySelectorAll('.ai-process-step-{{ ai_gen_id }}');
        this.prevBtn = this.querySelector('.ai-process-prev-{{ ai_gen_id }}');
        this.nextBtn = this.querySelector('.ai-process-next-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-process-slider-dot-{{ ai_gen_id }}');

        if (this.slides.length <= this.slidesPerView) {
          const controls = this.querySelector('.ai-process-slider-controls-{{ ai_gen_id }}');
          if (controls) controls.style.display = 'none';
          return;
        }

        this.setupEventListeners();
        this.updateSlider();
        
        if (this.autoplay) {
          this.startAutoplay();
          this.addEventListener('mouseenter', () => this.stopAutoplay());
          this.addEventListener('mouseleave', () => this.startAutoplay());
        }

        this.handleResize();
        window.addEventListener('resize', () => this.handleResize());
      }

      setupEventListeners() {
        if (this.prevBtn) {
          this.prevBtn.addEventListener('click', () => this.prevSlide());
        }

        if (this.nextBtn) {
          this.nextBtn.addEventListener('click', () => this.nextSlide());
        }

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goToSlide(index));
        });

        let startX = 0;
        let currentX = 0;
        let isDragging = false;

        this.track.addEventListener('touchstart', (e) => {
          startX = e.touches[0].clientX;
          isDragging = true;
          this.stopAutoplay();
        });

        this.track.addEventListener('touchmove', (e) => {
          if (!isDragging) return;
          currentX = e.touches[0].clientX;
        });

        this.track.addEventListener('touchend', () => {
          if (!isDragging) return;
          isDragging = false;
          
          const diff = startX - currentX;
          if (Math.abs(diff) > 50) {
            if (diff > 0) {
              this.nextSlide();
            } else {
              this.prevSlide();
            }
          }
          
          if (this.autoplay) {
            this.startAutoplay();
          }
        });
      }

      handleResize() {
        const containerWidth = this.querySelector('.ai-process-slider-{{ ai_gen_id }}').offsetWidth;
        const slideWidth = {{ block.settings.slide_width }};
        const gap = {{ block.settings.step_spacing }};
        
        if (window.innerWidth <= 480) {
          this.slidesPerView = 1;
        } else if (window.innerWidth <= 768) {
          this.slidesPerView = Math.floor(containerWidth / (slideWidth * 0.8 + gap));
        } else {
          this.slidesPerView = Math.floor(containerWidth / (slideWidth + gap));
        }
        
        this.slidesPerView = Math.max(1, Math.min(this.slidesPerView, this.slides.length));
        this.updateSlider();
      }

      updateSlider() {
        const slideWidth = this.slides[0].offsetWidth;
        const gap = {{ block.settings.step_spacing }};
        const offset = -(this.currentSlide * (slideWidth + gap));
        
        this.track.style.transform = `translateX(${offset}px)`;

        this.dots.forEach((dot, index) => {
          dot.classList.toggle('active', index === this.currentSlide);
        });

        if (this.prevBtn) {
          this.prevBtn.disabled = this.currentSlide === 0;
        }

        if (this.nextBtn) {
          this.nextBtn.disabled = this.currentSlide >= this.slides.length - this.slidesPerView;
        }
      }

      prevSlide() {
        if (this.currentSlide > 0) {
          this.currentSlide--;
          this.updateSlider();
        }
      }

      nextSlide() {
        if (this.currentSlide < this.slides.length - this.slidesPerView) {
          this.currentSlide++;
          this.updateSlider();
        }
      }

      goToSlide(index) {
        this.currentSlide = Math.min(index, this.slides.length - this.slidesPerView);
        this.updateSlider();
      }

      startAutoplay() {
        if (!this.autoplay) return;
        
        this.autoplayTimer = setInterval(() => {
          if (this.currentSlide >= this.slides.length - this.slidesPerView) {
            this.currentSlide = 0;
          } else {
            this.currentSlide++;
          }
          this.updateSlider();
        }, this.autoplayDelay);
      }

      stopAutoplay() {
        if (this.autoplayTimer) {
          clearInterval(this.autoplayTimer);
          this.autoplayTimer = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
        window.removeEventListener('resize', this.handleResize);
      }
    }

    customElements.define('process-steps-slider-{{ ai_gen_id }}', ProcessStepsSlider{{ ai_gen_id }});
  })();
</script>

