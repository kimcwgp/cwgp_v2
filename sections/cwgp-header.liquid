  }

  /* Header & Nav */
  header {
    background-color: #fff;
    box-shadow: 0 2px 5px rgb(0 0 0 / 0.1);
    position: sticky;
    top: 0;
    z-index: 1000;
  }

  nav {
    display: flex;
