                "label": "900"
                },
            ]
            },
            {
            "type": "range",
            "id": "description_size",
            "label": "Description Font Size",
            "min": 12,
            "max": 32,
            "step": 1,
            "unit": "px",
            "default": 16
            },
            {
            "type": "color",
            "id": "description_color",
            "label": "Description Color",
            "default": "#333333"
            }
        ]
    },
