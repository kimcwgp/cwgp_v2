            "label": "500"
            },
            {
            "value": "600",
            "label": "600"
            },
            {
            "value": "700",
            "label": "700"
            },
            {
            "value": "800",
            "label": "800"
            },
            {
            "value": "900",
            "label": "900"
            },
        ]
        },
        {
            "type": "color",
            "id": "description_color",
            "label": "Description Color",
            "default": "#333333"
        },
        {
        "type": "url",
        "id": "card_link",
        "label": "Card Link"
        }
        ]
    },
    {
        "type": "text_column",
        "name": "Text Column",
        "settings": [
            {
            "type": "range",
            "id": "column_width",
