<section 
  class="cwgp-resizable-cards
  {% unless section.settings.show_mobile %} hide-mobile{% endunless %}
  {% unless section.settings.show_desktop %} hide-desktop{% endunless %}"
  style="
    background-color: {{ section.settings.section_bg_color }};
    padding-top: {{ section.settings.padding-block-start }}px;
    padding-bottom: {{ section.settings.padding-block-end }}px;
    padding-left: {{ section.settings.padding-block-left }}px;
    padding-right: {{ section.settings.padding-block-right }}px;
  "
>

  <div class="cwgp-container" style="max-width: {{ section.settings.section_max_width }}px; margin: 0 auto;">

    <div 
    class="cwgp-resizable-cards-grid"
    style="
        flex-direction: {{ section.settings.cards_direction }};
        flex-wrap: {% if section.settings.cards_direction == 'row' %}nowrap{% else %}wrap{% endif %};
    ">

    {% for block in section.blocks %}
        {% case block.type %}

        {% when 'card' %}
            <div
              class="cwgp-card-wrapper"
              style="
                --card-width-mobile: {{ block.settings.card_width_mobile }};
                display:flex;
                flex-direction:column;
                align-items:center;
                flex: 0 0 calc({{ block.settings.card_width }}% - 20px);
              "
            >
            {% if block.settings.card_heading != blank %}
                <h3 
                    class="cwgp-card-heading"
                    style="
                    color: {{ block.settings.heading_color }};
                    font-size: {{ block.settings.heading_size }}px;
                    font-weight: {{ block.settings.card_heading_font_weight }};
                    margin-bottom: 30px;
                    "
                >
                    {{ block.settings.card_heading }}
                </h3>
                {% endif %}

            <div 
            class="cwgp-card"
            {{ block.shopify_attributes }}
            style="
            "
            >

       
                {% if block.settings.card_icon != blank %}
                <div class="cwgp-card-icon" 
                  style="
                  border: 3px solid {{ block.settings.card_border_color }};
                  border-top-left-radius: 8px;
                  border-top-right-radius: 8px;
                  border-bottom: 0;
                  "
                >
                    <img 
                    src="{{ block.settings.card_icon | image_url }}"
                    style="width: {{ block.settings.icon_width }}px;"
                    alt="icon"
                    >
                </div>
                {% endif %}

                <div class="cwgp-card-content" 
                  style="
                    background-color: {{ block.settings.card_bg_color }};
                    text-align: {{ block.settings.text_alignment }};
                    border: 3px solid {{ block.settings.card_border_color }};
                    border-bottom-left-radius: 8px;
                    border-bottom-right-radius: 8px;
                    border-top: 0;
                ">



                {% if block.settings.card_description != blank %}
                <p 
                    class="cwgp-card-description"
                    style="
                    color: {{ block.settings.description_color }};
                    font-size: {{ block.settings.description_size }}px;
                    font-weight: {{ block.settings.card_description_font_weight }};
                    padding: 16px 0;
                    "
                >
                  
                    {{ block.settings.card_description }}
                </p>
                {% endif %}

                </div>


            {% if block.settings.card_link != blank %}
                    <a href="{{ block.settings.card_link }}" class="{{ block.settings.card_link }}" style="display: flex; gap: 4px; align-items: center; justify-content: flex-end;">
                            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="#C6973D" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                    </a>
                {% endif %}

            </div>

            {% if block.settings.card_subdescription != blank %}
                <p 
                    class="cwgp-card-subdescription"
                    style="
                    color: {{ block.settings.subdescription_color }};
                    font-size: {{ block.settings.subdescription_size }}px;
                    font-weight: {{ block.settings.card_subdescription_font_weight }};
                    margin: 6px 0;
                    text-align: center;
                    padding: 10px 10px 0 10px;
                    "
                >
                  
                    {{ block.settings.card_subdescription }}
                </p>
                {% endif %}
            </div>

        {% endcase %}


    {% endfor %}

    </div>

  </div>

</section>

{% style %}

.cwgp-resizable-cards-grid{
  display:flex;
  flex-wrap:wrap;
  gap:20px;
}

.cwgp-card{
  width: 100%;
  box-sizing: border-box;
  border-radius: 8px;
  box-shadow: 0 6px 18px rgba(0,0,0,0.08);
  transition: all 0.25s ease;
}

.cwgp-card:hover{
  transform: translateY(-4px);
}

.cwgp-card-heading{
  margin-bottom:10px;
}

.cwgp-card-description{
  margin:0;
}

.cwgp-card-description p,
.cwgp-card-description span,
.cwgp-card-description h1,
.cwgp-card-description h2,
.cwgp-card-description h3,
.cwgp-card-description h4,
.cwgp-card-description h5,
.cwgp-card-description h6,
.cwgp-card-description strong,
.cwgp-text-description p,
.cwgp-text-description span,
.cwgp-text-description h1,
.cwgp-text-description h2,
.cwgp-text-description h3,
.cwgp-text-description h4,
.cwgp-text-description h5,
.cwgp-text-description h6,
.cwgp-text-description strong,
{
  font-size: inherit;
}

.cwgp-card-inner{
  display:flex;
  align-items:center;
}

.cwgp-card-icon img{
  display:block;
  height: 300px;
  border-top-left-radius: 5px;
  border-top-right-radius: 5px;
}

.cwgp-card-content{
  flex:1;
}

.cwgp-text-column{
  display:flex;
  flex-direction:column;
  justify-content:center;
}

.cwgp-text-heading{
  margin-bottom:12px;
  line-height: normal;
}

.cwgp-text-description p{
  margin:0;
}

.parent-link-list {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

.cwgp-socials-list {
  display: flex;
  padding:20px;
  border-radius:24px;
  align-items: center;
  gap: 20px;
}

.cwgp-link-list{
  padding:20px;
  border-radius:24px;
}

.cwgp-link-list-title{
  margin-bottom:0;
}

.cwgp-links{
  list-style:none;
  padding:0;
  margin:0;
}

.cwgp-links li{
  margin-bottom:8px;
}

.cwgp-links a{
  text-decoration:none;
  transition: opacity .2s;
}

.cwgp-links a:hover{
  opacity:.7;
}

.icons-list {
  display: flex;
  align-items: center;
  gap: 18px;
}

/* MOBILE */
@media (max-width: 767px) {

  .hide-mobile{
    display:none;
  }

  .cwgp-resizable-cards-grid{
    flex-direction: row !important;
    flex-wrap: wrap !important;
    justify-content: center;
  }

  .cwgp-card-wrapper{
    flex: 0 0 calc(var(--card-width-mobile) * 1% - 10px) !important;
    max-width: calc(var(--card-width-mobile) * 1% - 10px) !important;
    box-sizing: border-box;
  }

  .cwgp-card-icon img{
    height: 150px;
    width: 100%;
    object-fit: cover;
  }

}

/* DESKTOP */
@media (min-width:768px){
  .hide-desktop{
    display:none;
  }
}

{% endstyle %}

{% schema %}
{
  "name": "CWGP - Image Card",
  "settings": [
    {
        "type": "header",
        "content": "Section Layout"
    },
    {
    "type": "select",
    "id": "cards_direction",
    "label": "Cards Direction",
    "default": "row",
    "options": [
        {
        "value": "row",
        "label": "Horizontal"
        },
        {
        "value": "column",
        "label": "Vertical"
        }
    ]
    },
    {
        "type": "color",
        "id": "section_bg_color",
