                "label": "Vertical (Icon Top)"
                }
            ]
        },
        {
        "type": "image_picker",
        "id": "card_icon",
        "label": "Card Image"
        },
        {
            "type": "range",
            "id": "card_width",
            "label": "Card Width (%)",
            "min": 10,
            "max": 100,
            "step": 5,
            "default": 50
        },
        {
            "type": "range",
            "id": "card_width_mobile",
            "label": "Card Width Mobile(%)",
            "min": 10,
            "max": 100,
            "step": 5,
            "default": 50
        },
        {
        "type": "select",
        "id": "text_alignment",
        "label": "Text Alignment",
