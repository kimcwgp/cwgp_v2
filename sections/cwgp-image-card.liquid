        "default": "#f7f7f7"
    },
    {
        "type": "range",
        "id": "section_max_width",
        "label": "Section Max Width (px)",
        "min": 400,
        "max": 1600,
        "step": 20,
        "unit": "px",
        "default": 1440
    },
    {
        "type": "header",
        "content": "Section Padding"
    },
    {
        "type": "range",
        "id": "padding-block-start",
        "label": "Top padding",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "default": 0
    },
    {
        "type": "range",
        "id": "padding-block-end",
        "label": "Bottom padding",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "default": 0
    },
    {
        "type": "range",
        "id": "padding-block-left",
        "label": "Left padding",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "default": 0
    },
    {
        "type": "range",
        "id": "padding-block-right",
        "label": "Right padding",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "px",
        "default": 0
    },
    {
        "type": "header",
        "content": "Device Visibility"
    },
    {
        "type": "checkbox",
        "id": "show_mobile",
        "label": "Show Mobile",
        "default": true
    },
    {
        "type": "checkbox",
        "id": "show_desktop",
        "label": "Show Desktop",
        "default": true
    }
  ],
  "blocks": [
        {
        "type": "card",
        "name": "Card",
        "settings": [
        {
            "type": "header",
            "content": "Card Layout"
        },
        {
            "type": "select",
