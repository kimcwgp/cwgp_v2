{% comment %}
  Section: Stylish Form
  Description: A customizable contact or signup form with animated title and modern floating labels.
{% endcomment %}

<section class="custom-form-section" id="custom-form-{{ section.id }}">
  <form class="form">
    {% if section.settings.title != blank %}
      <p class="title">{{ section.settings.title }}</p>
    {% endif %}
    {% if section.settings.message != blank %}
      <p class="message">{{ section.settings.message }}</p>
    {% endif %}

    <label>
      <input class="input" type="text" name="name" required placeholder=" " />
      <span>Name</span>
    </label>

    <label>
      <input class="input" type="email" name="email" required placeholder=" " />
      <span>Email</span>
    </label>

    <label>
      <input class="input" type="text" name="subject" placeholder=" " />
      <span>Subject</span>
    </label>

    <label>
      <textarea class="input" name="message" rows="3" placeholder=" "></textarea>
      <span>Message</span>
    </label>

    <button type="submit" class="submit">{{ section.settings.button_label }}</button>

    {% if section.settings.signin_text != blank %}
      <p class="signin">{{ section.settings.signin_text }}</p>
    {% endif %}
  </form>

  <style>
    .form {
      display: flex;
      flex-direction: column;
      gap: 10px;
      max-width: 350px;
      background-color: #fff;
      padding: 20px;
      border-radius: 20px;
      position: relative;
      margin: 0 auto;
    }

    .title {
      font-size: 28px;
      color: royalblue;
      font-weight: 600;
      letter-spacing: -1px;
      position: relative;
      display: flex;
      align-items: center;
      padding-left: 30px;
    }

    .title::before,
    .title::after {
      position: absolute;
      content: "";
      height: 16px;
      width: 16px;
      border-radius: 50%;
      left: 0px;
      background-color: royalblue;
    }

    .title::before {
      width: 18px;
      height: 18px;
      background-color: royalblue;
    }

    .title::after {
      width: 18px;
      height: 18px;
      animation: pulse 1s linear infinite;
    }

    .message,
    .signin {
      color: rgba(88, 87, 87, 0.822);
      font-size: 14px;
    }

    .signin {
      text-align: center;
    }

    .signin a {
      color: royalblue;
    }

    .signin a:hover {
      text-decoration: underline royalblue;
    }

    .flex {
      display: flex;
      width: 100%;
      gap: 6px;
    }

    .form label {
      position: relative;
    }

    .form label .input {
      width: 100%;
      padding: 10px 10px 20px 10px;
      outline: 0;
      border: 1px solid rgba(105, 105, 105, 0.397);
      border-radius: 10px;
      resize: none;
    }

    .form label .input + span {
      position: absolute;
      left: 10px;
      top: 15px;
      color: grey;
      font-size: 0.9em;
      cursor: text;
      transition: 0.3s ease;
    }

    .form label .input:placeholder-shown + span {
      top: 15px;
      font-size: 0.9em;
    }

    .form label .input:focus + span,
    .form label .input:valid + span {
      top: 30px;
      font-size: 0.7em;
      font-weight: 600;
    }

    .form label .input:valid + span {
      color: green;
    }

    .submit {
      border: none;
      outline: none;
      background-color: royalblue;
      padding: 10px;
      border-radius: 10px;
      color: #fff;
      font-size: 16px;
      transition: all 0.3s ease;
      cursor: pointer;
    }

    .submit:hover {
      background-color: rgb(56, 90, 194);
    }

    @keyframes pulse {
      from {
        transform: scale(0.9);
        opacity: 1;
      }
      to {
        transform: scale(1.8);
        opacity: 0;
      }
    }
  </style>
</section>

{% schema %}
{
  "name": "CWGP Contact Form",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Form Title",
      "default": "Contact Us"
    },
    {
      "type": "text",
      "id": "message",
      "label": "Form Message",
      "default": "We’d love to hear from you!"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Submit Button Label",
      "default": "Send Message"
    },
    {
      "type": "richtext",
      "id": "signin_text",
      "label": "Footer / Sign-in Text",
      "default": "<p>Already have an account? <a href=\"/account/login\">Sign in</a></p>"
    }
  ],
  "presets": [
    {
      "name": "CWGP Contact Form"
    }
  ]
}
{% endschema %}
